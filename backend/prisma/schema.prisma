generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String            @id @default(uuid()) @db.Uuid
  firstName             String            @map("first_name") @db.VarChar(100)
  lastName              String            @map("last_name") @db.VarChar(100)
  email                 String            @unique @db.VarChar(255)
  password              String?           @db.VarChar(255)
  googleId              String?           @unique @map("google_id") @db.VarChar(255)
  phoneNumber           String?           @map("phone_number") @db.VarChar(30)
  type                  UserType          @default(PENDING)
  imageUrl              String?           @map("image_url") @db.VarChar(500)
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")
  refreshTokens         RefreshToken[]
  broadcastsCreated     Broadcast[]       @relation("BroadcastCreator")
  conversationParticipants ConversationParticipant[]
  messagesSent          Message[]         @relation("MessageSender")
  projectsAsClient      Project[]         @relation("ProjectClient")
  provider              Provider?
  trustedRelations      TrustedRelation[] @relation("TrustedUser")
  auditLogs             AuditLog[]        @relation("AuditPerformer")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Provider {
  id                      String              @id @default(uuid()) @db.Uuid
  userId                  String              @unique @map("user_id") @db.Uuid
  license                 String?             @db.VarChar(100)
  idVerificationImg       String?             @map("id_verification_img") @db.VarChar(500)
  profession              String?             @db.VarChar(150)
  description             String?             @db.VarChar(300)
  isVerified              VerificationStatus  @default(PENDING) @map("is_verified")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")
  broadcastResponses      BroadcastResponse[]
  broadcastConfirmed      Broadcast[]         @relation("BroadcastConfirmedProvider")
  projectAssignments      ProjectProvider[]
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustedRelations        TrustedRelation[]   @relation("TrustedProvider")

  @@map("providers")
}

model TrustedRelation {
  id         String                @id @default(uuid()) @db.Uuid
  userId     String                @map("user_id") @db.Uuid
  providerId String                @map("provider_id") @db.Uuid
  status     TrustedRelationStatus @default(PENDING)
  createdAt  DateTime              @default(now()) @map("created_at")
  blockedById String?               @map("blocked_by") @db.Uuid
  updatedAt  DateTime              @updatedAt @map("updated_at")
  provider   Provider              @relation("TrustedProvider", fields: [providerId], references: [id], onDelete: Cascade)
  user       User                  @relation("TrustedUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@map("trusted_relations")
}

model Broadcast {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @map("user_id") @db.Uuid
  title               String              @db.VarChar(255)
  description         String?
  location            String?             @db.VarChar(255)
  status              BroadcastStatus     @default(OPEN)
  type                BroadcastType       @default(NORMAL)
  maxProviders        Int?                @map("max_providers")
  providerConfirmedId String?             @map("provider_confirmed_id") @db.Uuid
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  responses           BroadcastResponse[]
  providerConfirmed   Provider?           @relation("BroadcastConfirmedProvider", fields: [providerConfirmedId], references: [id])
  user                User                @relation("BroadcastCreator", fields: [userId], references: [id], onDelete: Cascade)
  project             Project?            @relation("BroadcastProject")

  @@map("broadcasts")
}

model BroadcastResponse {
  id          String                  @id @default(uuid()) @db.Uuid
  broadcastId String                  @map("broadcast_id") @db.Uuid
  providerId  String                  @map("provider_id") @db.Uuid
  message     String?
  price       Decimal?                @db.Decimal(10, 2)
  task        String?                 @db.VarChar(255)
  status      BroadcastResponseStatus @default(PENDING)
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  broadcast   Broadcast               @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  provider    Provider                @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, providerId])
  @@map("broadcast_responses")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  isGroup   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages Message[]
}

model ConversationParticipant {
  conversationId String @db.Uuid
  userId         String @db.Uuid

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  senderId       String       @map("sender_id") @db.Uuid
  type           MessageType
  content        String
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Project {
  id          String            @id @default(uuid()) @db.Uuid
  clientId    String            @map("client_id") @db.Uuid
  broadcastId String?           @unique @map("broadcast_id") @db.Uuid
  title       String            @db.VarChar(255)
  description String?
  status      ProjectStatus     @default(DRAFT)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  providers   ProjectProvider[]
  client      User              @relation("ProjectClient", fields: [clientId], references: [id], onDelete: Cascade)
  broadcast   Broadcast?        @relation("BroadcastProject", fields: [broadcastId], references: [id], onDelete: SetNull)

  @@map("projects")
}

model ProjectProvider {
  id         String                @id @default(uuid()) @db.Uuid
  projectId  String                @map("project_id") @db.Uuid
  providerId String                @map("provider_id") @db.Uuid
  status     ProjectProviderStatus @default(INVITED)
  role       ProjectProviderRole   @default(COLLABORATOR)
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")
  project    Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider   Provider              @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([projectId, providerId])
  @@map("project_providers")
}

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  action      AdminAction
  performedBy String      @db.Uuid
  targetId    String?     @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  performer   User        @relation("AuditPerformer", fields: [performedBy], references: [id])

  @@map("audit_logs")
}

enum MessageType {
  TEXT
  FILE
}

enum AdminAction {
  PROVIDER_APPROVED
  PROVIDER_REJECTED
  USER_PROMOTED_TO_ADMIN
  PROVIDER_REMOVED
  USER_DELETED
}

enum UserType {
  PENDING
  CLIENT
  PROVIDER
  ADMIN
  ROOT
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TrustedRelationStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum BroadcastStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum BroadcastResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectProviderStatus {
  INVITED
  ACTIVE
  REMOVED
  COMPLETED
}

enum ProjectProviderRole {
  LEAD
  COLLABORATOR
  OBSERVER
}

enum BroadcastType {
  NORMAL
  GROUP
}
